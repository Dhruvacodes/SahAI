# Application settings
APP_NAME=Sahai API
APP_ENV=development
APP_VERSION=0.1.0

# Sarvam (PRIMARY — apply for free credits via Startup Program)
SARVAM_API_KEY=

# OpenAI (fallback only)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-7

# Database
DATABASE_URL=postgresql://postgres:sahai@localhost:5432/postgres

# Auth
JWT_SECRET_KEY=replace-with-a-development-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# Privacy and safety defaults
CONSENT_VERSION=sahai-consent-v1
RAW_AUDIO_STORAGE_ENABLED=false
